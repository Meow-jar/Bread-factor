[sub_resource type="GDScript" id="GDScript_uxm8v"]
script/source = "extends Node3D
var waterbool = false
var flourbool = false
var dough = preload(\"res://Ingredients/dough.tscn\")
var water_parent = load(\"res://Ingredients/water.tscn\").instantiate()
@onready var water = $\"../spawn_water\"
@onready var flour = $\"../flour\"
@onready var spawn = $spawn

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.
func spawn_object(x, y, z):
	var new_dough = dough.instantiate()
	
	new_dough.position.x = spawn.position.x
	new_dough.position.y = spawn.position.y
	new_dough.position.z = spawn.position.z
	
	add_child(new_dough)

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	if waterbool == true and flourbool == true :
		print(\"хлеб готов\")
		spawn_object(0,0,0) 
		water.queue_free()
		flour.queue_free()
	pass


func _on_water_tg_body_entered(body: Node3D) -> void:
	print(\"Body: \", body, \" water: \", water)
w	if body.get_parent() == water:
		Input.action_press(\"action\")
		await get_tree().create_timer(0.5).timeout 
		waterbool = true
		print(\"water = \", waterbool)
	
	pass # Replace with function body.


func _on_water_tg_body_exited(body: Node3D) -> void:
	if body == water:
		waterbool = false
		print(\"water = \", waterbool)
	
	pass # Replace with function body.


func _on_flour_tg_body_entered(body: Node3D) -> void:
	if body == flour:
		Input.action_press(\"action\")
		await get_tree().create_timer(0.5).timeout 
		flourbool = true
		print(\"flour = \", flourbool)
	pass # Replace with function body.


func _on_flour_tg_body_exited(body: Node3D) -> void:
	if body == flour:
		flourbool = false
		print(\"flour = \", flourbool)
	pass # Replace with function body.
"

