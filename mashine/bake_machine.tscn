[sub_resource type="GDScript" id="GDScript_fhs66"]
script/source = "extends Node3D
var doughbool = false
var bread = preload(\"res://Ingredients/bread.tscn\")
var dough = \"res://Ingredients/dough.tscn\"
@onready var spawn = $spawn
@onready var colision_player = $\".\"
var dough_inven = 0


# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	if dough_inven > 0 and dough_inven < 2:
		dough_inven = dough_inven - 1
		spawn_object()
	pass

	
func spawn_object():
	var new_bread = bread.instantiate()
	
	new_bread.position.x = spawn.position.x
	new_bread.position.y = spawn.position.y
	new_bread.position.z = spawn.position.z
	
	new_bread.collision_layer = 1
	add_child(new_bread)

func _on_dough_tg_body_entered(body: Node3D) -> void:
	print(\"Body: \", body, \"dough:\", dough)
	if body.scene_file_path == dough:
		dough_inven = dough_inven + 1
		if dough_inven > 0 and dough_inven < 2:
			print (\"dough = \",dough_inven)
			body.queue_free()
		doughbool = true
		print(doughbool)
	pass # Replace with function body.


func _on_dough_tg_body_exited(body: Node3D) -> void:
	if body.scene_file_path == dough:
		doughbool = false
		print(doughbool)
	pass # Replace with function body.
"

