[sub_resource type="GDScript" id="GDScript_5415g"]
script/source = "extends Node3D
@onready var spawn = $spawn
@onready var flour = preload(\"res://Ingredients/flour.tscn\")
# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	for i in 5:
		spawn_object(0,0,0)
	
	pass # Replace with function body.


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	pass
	
func spawn_object(x, y, z):
	var new_flour = flour.instantiate()
	
	new_flour.position.x = spawn.position.x
	new_flour.position.y = spawn.position.y
	new_flour.position.z = spawn.position.z
	add_child(new_flour)
"

